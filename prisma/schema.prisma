generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Expense {
  id        String   @id @default(cuid())
  date      String   // YYYY-MM-DD CST
  amountRMB Float
  amountIDR Float
  category  String   // FOOD | PERSONAL | OTHER | FIXED
  note      String?
  createdAt DateTime @default(now())

  @@index([date])
  @@index([category])
}

model MonthlySettings {
  id           String @id @default(cuid())
  month        String @unique // YYYY-MM
  allowanceIDR Int
  allowanceRMB Float
  idrPerRmb    Float
  paydayDay    Int
}

model FixedCost {
  id         String  @id @default(cuid())
  name       String
  amountRMB  Float
  billingDay Int?
  active     Boolean @default(true)
}

model Income {
  id        String   @id @default(cuid())
  date      String   // YYYY-MM-DD CST
  amountRMB Float
  amountIDR Float
  source    String   // SALARY | BONUS | SIDE | OTHER
  note      String?
  createdAt DateTime @default(now())

  @@index([date])
  @@index([source])
}

model DailyBudget {
  id           String   @id @default(cuid())
  date         String   @unique // YYYY-MM-DD CST
  baseAmount   Float    // always 37
  carryover    Float    // positive = bonus, negative = debt
  budgetAmount Float    // clamp(base + carryover, 10, 100)
  spent        Float    @default(0)
  updatedAt    DateTime @updatedAt
}

model Macro {
  id        String   @id @default(cuid())
  date      String   // YYYY-MM-DD CST
  amountRMB Float
  amountIDR Float
  type      String   // INCOME | EXPENSE
  category  String   // see lib/macro.ts
  note      String?
  createdAt DateTime @default(now())

  @@index([date])
  @@index([type])
}
